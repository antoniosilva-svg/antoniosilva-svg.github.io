---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { careerTimeline, featuredExperience, profile, strengths } from '../../data/portfolio';
---
<BaseLayout title="Área RH | António José Abreu e Silva" description="Resumo profissional para recrutadores.">
  <section class="bg-wine py-20 text-white lg:py-28"><div class="mx-auto max-w-5xl px-5 lg:px-8"><p class="eyebrow !text-gold-light">Área reservada a recrutadores</p><h1 class="display mt-5 text-5xl sm:text-6xl">Um resumo claro<br />do meu percurso.</h1><p class="mt-7 max-w-2xl text-lg leading-8 text-white/75">{profile.recruiterSummary}</p><a class="mt-9 inline-flex rounded-full bg-white px-6 py-3 text-sm font-bold text-wine" href="/biblioteca/">Consultar CV e documentos →</a></div></section>
  <section class="py-20"><div class="mx-auto grid max-w-5xl gap-12 px-5 lg:grid-cols-2 lg:px-8"><div><p class="eyebrow">Perfil</p><h2 class="display mt-4 text-4xl text-wine">Pessoas, processos e propósito.</h2><p class="mt-6 leading-8 text-ink/70">{profile.summary}</p></div><div class="rounded-2xl border border-gold/20 bg-white p-7 shadow-lg shadow-wine/5"><p class="eyebrow">Áreas de contributo</p><ul class="mt-5 space-y-4">{strengths.map((strength) => <li class="flex gap-3 text-ink/75"><span class="text-gold">✦</span>{strength}</li>)}</ul></div></div></section>
  <section class="border-t border-gold/15 bg-white/40 py-20"><div class="mx-auto max-w-5xl px-5 lg:px-8"><p class="eyebrow">Cronologia profissional</p><h2 class="display mt-4 text-4xl text-wine">Um percurso construído em contextos diferentes.</h2><ol class="mt-10 border-l border-gold/40 pl-7">{careerTimeline.map((item) => <li class="relative pb-10 last:pb-0"><span class="absolute -left-[2.05rem] top-1 h-3.5 w-3.5 rounded-full border-2 border-pearl bg-gold"></span><p class="text-xs font-bold uppercase tracking-[.15em] text-gold">{item.period}</p><h3 class="mt-2 font-display text-2xl text-wine">{item.role}</h3><p class="mt-1 font-semibold text-ink/75">{item.organisation}</p><p class="mt-3 max-w-3xl leading-7 text-ink/65">{item.text}</p></li>)}</ol></div></section>
  <section class="border-y border-gold/15 bg-white/45 py-20"><div class="mx-auto max-w-5xl px-5 lg:px-8"><p class="eyebrow">Experiência em destaque</p><div class="mt-8 grid gap-4 md:grid-cols-2">{featuredExperience.map((item) => <article class="rounded-2xl border border-gold/20 bg-pearl p-6"><p class="text-xs font-bold uppercase tracking-[.15em] text-gold">{item.area}</p><h2 class="mt-3 font-display text-2xl text-wine">{item.title}</h2><p class="mt-3 leading-7 text-ink/70">{item.text}</p></article>)}</div></div></section>
  <section class="border-t border-gold/15 bg-white/50 py-16"><div class="mx-auto max-w-5xl px-5 lg:px-8"><p class="eyebrow">Contacto</p><p class="mt-4 text-xl text-ink/75">Os contactos e o CV final serão disponibilizados nesta área antes da publicação do site.</p></div></section>
</BaseLayout>
