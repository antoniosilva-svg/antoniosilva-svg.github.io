---
import BaseLayout from '../layouts/BaseLayout.astro';
import { featuredExperience, profile } from '../data/portfolio';

const highlights = [
  ['Pessoas', 'Desenvolvimento de equipas, comunicação e relação humana.'],
  ['Projetos', 'Planeamento rigoroso, criatividade e sentido de impacto.'],
  ['Comunidades', 'Intervenção social centrada em necessidades reais.'],
];
const projects = [
  { type: 'Experiência', title: 'Urgezes Solidário', text: 'Participação numa iniciativa de intervenção comunitária, com uma passagem breve e contributos concretos.', href: '/projetos/urgezes-solidario/' },
  { type: 'Proposta estratégica', title: 'Guardizela +65', text: 'Conceito de envelhecimento ativo desenvolvido para Guardizela. Foi concebido e apresentado, mas não chegou a ser implementado.', href: '/projetos/guardizela-65/' },
  { type: 'Publicação', title: 'Aprendendo com os Animais', text: 'Livro infantil que junta criatividade, educação e valores para os mais novos.', href: '/projetos/aprendendo-com-os-animais/' },
];
---
<BaseLayout title="António José Abreu e Silva | ORZHOV" description="Portefólio profissional de António José Abreu e Silva.">
  <section class="relative isolate overflow-hidden">
    <div class="absolute inset-0 -z-10 bg-[radial-gradient(ellipse_at_top_right,_rgba(223,194,125,.28),transparent_47%),radial-gradient(ellipse_at_bottom_left,_rgba(109,31,49,.1),transparent_45%)]"></div>
    <div class="mx-auto grid min-h-[680px] max-w-7xl items-center gap-12 px-5 py-20 lg:grid-cols-[1.1fr_.9fr] lg:px-8 lg:py-28">
      <div>
        <p class="eyebrow">Portefólio profissional</p>
        <div class="mt-7 max-w-3xl">
          <h1 class="display text-5xl leading-[.95] text-ink sm:text-6xl lg:text-7xl">António José<br /><span class="text-wine">Abreu e Silva</span></h1>
          <p class="mt-8 max-w-xl text-lg leading-8 text-ink/70">{profile.summary}</p>
        </div>
        <div class="mt-10 flex flex-wrap gap-3">
          <a href="/rh/" class="rounded-full bg-wine px-6 py-3 text-sm font-bold text-white shadow-lg shadow-wine/20 transition hover:-translate-y-0.5 hover:bg-wine-dark">Visita para recrutadores <span aria-hidden="true">→</span></a>
          <a href="#percurso" class="rounded-full border border-gold/70 bg-white/50 px-6 py-3 text-sm font-bold text-wine transition hover:border-wine hover:bg-white">Conhecer o percurso</a>
        </div>
        <p class="mt-7 text-xs font-medium text-ink/45">Psicologia Organizacional · Gestão de Equipas · Projetos Sociais</p>
      </div>
      <div class="relative mx-auto w-full max-w-md lg:ml-auto">
        <div class="aspect-[4/5] overflow-hidden rounded-[2rem] border border-gold/30 bg-gradient-to-br from-[#ede4d2] via-[#fffdfa] to-[#d6bd82] p-4 shadow-2xl shadow-wine/10">
          <div class="relative h-full overflow-hidden rounded-[1.5rem] border border-white/70 bg-[#e7dfd0]">
            <img src="/images/antonio-silva-portrait.png" alt="Retrato profissional de António José Abreu e Silva" class="h-full w-full object-cover object-[50%_35%]" />
            <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-wine-dark/90 via-wine/50 to-transparent px-7 pb-7 pt-24 text-white">
              <p class="font-display text-2xl leading-snug sm:text-3xl">“O trabalho ganha outro significado quando deixa uma marca positiva nas pessoas.”</p>
              <p class="mt-4 text-xs font-bold uppercase tracking-[.18em] text-gold-light">António Silva</p>
            </div>
            <span class="absolute left-7 top-7 grid h-12 w-12 place-items-center rounded-full border border-gold/60 bg-pearl/90 font-display text-2xl text-wine shadow-lg">A</span>
          </div>
        </div>
        <div class="absolute -top-5 -left-5 hidden rounded-2xl border border-gold/25 bg-white/85 px-5 py-4 shadow-xl backdrop-blur sm:block"><p class="eyebrow text-[.6rem]">Disponível para</p><p class="mt-1 font-display text-xl text-wine">Novos desafios</p></div>
      </div>
    </div>
  </section>

  <section id="sobre" class="border-y border-gold/15 bg-white/40 py-20">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="grid gap-10 lg:grid-cols-[.72fr_1.28fr]">
        <div><p class="eyebrow">Uma forma de estar</p><h2 class="display mt-4 text-4xl text-wine">Mais do que uma lista de funções.</h2></div>
        <div><p class="max-w-3xl text-xl leading-9 text-ink/75">O meu percurso cruza aviação, gestão operacional, intervenção social e criação de projetos. Em cada contexto, procuro escutar bem, organizar o que é complexo e transformar intenção em ação.</p><div class="mt-9 gold-rule"></div></div>
      </div>
      <div class="mt-12 grid gap-4 md:grid-cols-3">
        {highlights.map(([title, text]) => <article class="card rounded-2xl p-6 transition"><p class="font-display text-2xl text-wine">{title}</p><p class="mt-3 leading-7 text-ink/65">{text}</p></article>)}
      </div>
    </div>
  </section>

  <section id="percurso" class="py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-5 lg:px-8"><p class="eyebrow">Percurso em síntese</p><div class="mt-4 flex flex-col justify-between gap-5 md:flex-row md:items-end"><h2 class="display max-w-2xl text-4xl text-wine sm:text-5xl">Experiências que moldaram a minha forma de trabalhar.</h2><a href="/rh/" class="text-sm font-bold text-wine underline decoration-gold underline-offset-8">Ver perfil de recrutamento →</a></div>
      <div class="mt-12 grid gap-px overflow-hidden rounded-2xl border border-gold/20 bg-gold/20 md:grid-cols-2">
        {featuredExperience.map((item) => <article class="bg-pearl p-7"><p class="eyebrow">{item.area}</p><h3 class="mt-3 font-display text-2xl text-wine">{item.title}</h3><p class="mt-3 leading-7 text-ink/65">{item.text}</p></article>)}
      </div>
    </div>
  </section>

  <section id="projetos" class="bg-wine py-20 text-white lg:py-28">
    <div class="mx-auto max-w-7xl px-5 lg:px-8"><p class="eyebrow !text-gold-light">Projetos e ideias</p><h2 class="display mt-4 max-w-2xl text-4xl sm:text-5xl">Trabalho apresentado com contexto e transparência.</h2><p class="mt-5 max-w-2xl leading-7 text-white/70">Cada entrada distingue claramente o que foi realizado, onde existiu participação, e o que ficou ao nível de proposta ou estudo.</p>
      <div class="mt-12 grid gap-5 lg:grid-cols-3">{projects.map((project, index) => <a class="group rounded-2xl border border-white/15 bg-white/[.07] p-7 transition hover:-translate-y-1 hover:bg-white/[.12]" href={project.href}><p class="text-xs font-bold uppercase tracking-[.16em] text-gold-light">0{index + 1} · {project.type}</p><h3 class="mt-6 font-display text-3xl">{project.title}</h3><p class="mt-4 leading-7 text-white/70">{project.text}</p><p class="mt-8 text-sm font-bold text-gold-light">Ver contexto <span aria-hidden="true">→</span></p></a>)}</div>
    </div>
  </section>

  <section class="py-20 text-center lg:py-28"><div class="mx-auto max-w-2xl px-5"><p class="eyebrow">Um convite</p><h2 class="display mt-4 text-4xl text-wine sm:text-5xl">Obrigado por dedicar alguns minutos ao meu percurso.</h2><p class="mt-6 leading-8 text-ink/65">Na área de recrutamento encontra uma apresentação mais direta, CV e informação profissional organizada.</p><a href="/rh/" class="mt-9 inline-flex rounded-full border border-gold bg-white px-6 py-3 text-sm font-bold text-wine transition hover:bg-gold hover:text-white">Entrar na área RH →</a></div></section>
</BaseLayout>
