---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { certifications } from '../../data/portfolio';
const documents = [
  ['Currículo', 'CV atualizado em português e inglês', 'A adicionar'],
  ['Certificados', 'Formação, diplomas e certificações relevantes', 'Em organização'],
  ['Projetos', 'Relatórios, apresentações e materiais selecionados', 'A organizar'],
];
---
<BaseLayout title="Biblioteca | António José Abreu e Silva">
  <section class="mx-auto max-w-7xl px-5 py-20 lg:px-8 lg:py-28"><p class="eyebrow">Biblioteca profissional</p><h1 class="display mt-4 text-5xl text-wine sm:text-6xl">Documentos com<br />contexto.</h1><p class="mt-6 max-w-2xl text-lg leading-8 text-ink/65">Esta biblioteca será preenchida apenas com documentos validados e adequados à partilha com recrutadores.</p><div class="mt-14 grid gap-5 md:grid-cols-3">{documents.map(([title, text, status]) => <article class="card rounded-2xl p-7"><p class="text-xs font-bold uppercase tracking-[.16em] text-gold">{status}</p><h2 class="mt-5 font-display text-3xl text-wine">{title}</h2><p class="mt-4 leading-7 text-ink/65">{text}</p></article>)}</div></section>
  <section class="border-t border-gold/15 bg-white/45 py-20"><div class="mx-auto max-w-7xl px-5 lg:px-8"><p class="eyebrow">Formação certificada</p><h2 class="display mt-4 text-4xl text-wine">Aprendizagem contínua.</h2><p class="mt-5 max-w-2xl leading-7 text-ink/65">Uma seleção da formação relevante para contextos de coordenação, serviço, processos e desenvolvimento de pessoas.</p><div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">{certifications.map((certificate) => <article class="rounded-2xl border border-gold/20 bg-pearl p-6"><p class="text-xs font-bold uppercase tracking-[.16em] text-gold">{certificate.year}</p><h3 class="mt-3 font-display text-2xl text-wine">{certificate.title}</h3><p class="mt-3 leading-7 text-ink/65">{certificate.detail}</p></article>)}</div><p class="mt-8 text-sm leading-6 text-ink/55">Os comprovativos completos serão partilhados apenas quando adequados ao processo de recrutamento.</p></div></section>
</BaseLayout>
